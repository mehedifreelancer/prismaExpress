{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".", // Change from "./src" to "."
    "rootDirs": ["./src", "./generated"], // Add this line
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "types": ["node", "express"]
  },
  "include": [
    "src/**/*",
    "generated/**/*" // Add generated folder
  ],
  "exclude": ["node_modules", "dist"]
}
